{
    "version": 2,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/",
            "dest": "app/web/pages/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "app/web/pages/$1"
        }
    ]
}
{
    "version": 2,
    "routes": [
        {
            "src": "/",
            "dest": "/app/web/index.html"
        },
        {
            "src": "/index.html",
            "dest": "/app/web/index.html"
        },
        {
            "src": "/resource.html",
            "dest": "/app/web/resource.html"
        },
        {
            "src": "/help.html",
            "dest": "/app/web/help.html"
        },
        {
            "src": "/login.html",
            "dest": "/app/web/login.html"
        },
        {
            "src": "/success.html",
            "dest": "/app/web/success.html"
        },
        {
            "src": "/css/(.*)",
            "dest": "/app/web/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/app/web/js/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/app/web/images/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/app/web/$1"
        }
    ]
}
{
    "version": 2,
    "routes": [
        {
            "src": "/",
            "dest": "/adminlogin.html"
        },
        {
            "src": "/adminlogin.html",
            "dest": "/adminlogin.html"
        },
        {
            "src": "/dashboard.html",
            "dest": "/dashboard.html"
        },
        {
            "src": "/css/(.*)",
            "dest": "/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/js/$1"
        }
    ]
}
{
    "version": 2,
    "rewrites": [
        {
            "source": "/",
            "destination": "/login.html"
        },
        {
            "source": "/login",
            "destination": "/login.html"
        },
        {
            "source": "/dashboard",
            "destination": "/dashboard.html"
        },
        {
            "source": "/dashboard.html",
            "destination": "/dashboard.html"
        },
        {
            "source": "/css/:file",
            "destination": "/css/:file"
        },
        {
            "source": "/js/:file",
            "destination": "/js/:file"
        }
    ]
}